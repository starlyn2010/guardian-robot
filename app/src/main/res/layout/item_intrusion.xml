<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="6dp"
    android:paddingHorizontal="4dp">

    <View
        android:id="@+id/intrusionColorDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/circle_indicator"
        android:layout_marginEnd="8dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvIntrusionType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="persona"
            android:textColor="#FFC9D1D9"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvIntrusionDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="85% | 15%"
            android:textColor="#FF8B949E"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvIntrusionTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12:34:56"
        android:textColor="#FF6E7681"
        android:textSize="10sp" />
</LinearLayout>
